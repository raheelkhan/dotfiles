# Oh my tmux! - VSCode Dark+ Theme
# https://github.com/gpakosz/.tmux

# -- VSCode Dark+ color palette ------------------------------------------------

tmux_conf_theme_colour_1="#1e1e1e"    # editor background
tmux_conf_theme_colour_2="#252526"    # sidebar background
tmux_conf_theme_colour_3="#808080"    # muted text
tmux_conf_theme_colour_4="#569cd6"    # blue (accent)
tmux_conf_theme_colour_5="#dcdcaa"    # yellow (alerts)
tmux_conf_theme_colour_6="#1e1e1e"    # dark bg
tmux_conf_theme_colour_7="#d4d4d4"    # foreground text
tmux_conf_theme_colour_8="#1e1e1e"    # dark bg
tmux_conf_theme_colour_9="#569cd6"    # blue (session label)
tmux_conf_theme_colour_10="#c586c0"   # purple (section)
tmux_conf_theme_colour_11="#6a9955"   # green (section)
tmux_conf_theme_colour_12="#808080"   # muted text
tmux_conf_theme_colour_13="#d4d4d4"   # foreground text
tmux_conf_theme_colour_14="#1e1e1e"   # dark bg
tmux_conf_theme_colour_15="#252526"   # sidebar bg
tmux_conf_theme_colour_16="#569cd6"   # blue (right section)
tmux_conf_theme_colour_17="#333333"   # dark grey

# -- pane borders --------------------------------------------------------------

tmux_conf_theme_pane_border="$tmux_conf_theme_colour_2"
tmux_conf_theme_pane_active_border="$tmux_conf_theme_colour_4"

# -- powerline separators ------------------------------------------------------

tmux_conf_theme_left_separator_main='\uE0B0'
tmux_conf_theme_left_separator_sub='\uE0B1'
tmux_conf_theme_right_separator_main='\uE0B2'
tmux_conf_theme_right_separator_sub='\uE0B3'

# -- status line ---------------------------------------------------------------

tmux_conf_theme_status_left=" #S "
tmux_conf_theme_status_right=" #{prefix}#{mouse} , %R , #{b:pane_current_path} "

# status left style: session name in blue
tmux_conf_theme_status_left_fg="#1e1e1e,#d4d4d4,#d4d4d4"
tmux_conf_theme_status_left_bg="#569cd6,#333333,#252526"
tmux_conf_theme_status_left_attr="bold,none,none"

# status right style
tmux_conf_theme_status_right_fg="#808080,#d4d4d4,#1e1e1e"
tmux_conf_theme_status_right_bg="#252526,#569cd6,#6a9955"
tmux_conf_theme_status_right_attr="none,none,bold"

# -- window tabs ---------------------------------------------------------------

# inactive window
tmux_conf_theme_window_status_fg="#808080"
tmux_conf_theme_window_status_bg="#1e1e1e"
tmux_conf_theme_window_status_attr="none"
tmux_conf_theme_window_status_format=" #W "

# active window - blue highlight
tmux_conf_theme_window_status_current_fg="#ffffff"
tmux_conf_theme_window_status_current_bg="#569cd6"
tmux_conf_theme_window_status_current_attr="bold"
tmux_conf_theme_window_status_current_format=" #W "

# last active window
tmux_conf_theme_window_status_last_fg="#569cd6"
tmux_conf_theme_window_status_last_bg="#252526"
tmux_conf_theme_window_status_last_attr="none"

# -- user customizations -------------------------------------------------------

# vi mode
set-window-option -g mode-keys vi

# mouse support
set -g mouse on

# focus events for nvim auto-reload
set -g focus-events on

# copy to OS clipboard
tmux_conf_copy_to_os_clipboard=true

# auto-rename windows based on running command
set -g automatic-rename on
set -g automatic-rename-format "#{?#{==:#{pane_current_command},nvim},#{b:pane_current_path},#{?#{==:#{pane_current_command},zsh},terminal,claude}}"
