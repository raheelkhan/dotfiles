# ==========================
# Ghostty Terminal Config
# ==========================

# Appearance
theme = Dark+
cursor-style-blink = true

# Font
font-family = FiraCode Nerd Font
font-style = Medium
font-size = 16
font-feature = calt
font-feature = liga
font-feature = dlig

# Cursor
cursor-style = block
shell-integration-features = no-cursor,no-title

# Window
macos-titlebar-style = tabs
window-theme = dark

# Disable splits (use tabs instead, like iTerm2)
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind



